# NeuroSync cloud config — copy to `.env` and fill in. `.env` is gitignored. See CLOUD_SETUP.md.

# NeuroSync's OWN Convex deployment (never the landing-page waitlist deployment).
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Team access token — used once to create the deployment.
CONVEX_TEAM_TOKEN=

# Clerk email auth.
CLERK_PUBLISHABLE_KEY=      # pk_test_… / pk_live_… — safe to ship in the app frontend
CLERK_FRONTEND_API_URL=    # https://<instance>.clerk.accounts.dev (decode from the publishable key)
CLERK_SECRET_KEY=          # sk_… ADMIN, CLI/backend only — NEVER ship in the app, NEVER commit
